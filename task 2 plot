

t = 0:0.1:10;

figure

subplot(3,1,1)
plot(t,exp(-0.5*t),'r-o','LineWidth',1.5)
title('e^{-0.5t}')
xlabel('t')
ylabel('Value')
grid on
legend('e^{-0.5t}')

subplot(3,1,2)
plot(t,cos(2*t),'b-*','LineWidth',1.5)
title('cos(2t)')
xlabel('t')
ylabel('Value')
grid on
legend('cos(2t)')

subplot(3,1,3)
plot(t,exp(-0.5*t),'k-s','LineWidth',1.5)
title('e^{-0.5t}')
xlabel('t')
ylabel('Value')
grid on
legend('e^{-0.5t}')
